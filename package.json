{
  "name": "foundational-apparel-ecommerce",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "axe-core": "^4.9.0",
    "eslint": "^9.9.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-vue": "^9.23.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "vite": "^5.2.0",
    "vite-node": "^1.6.0",
    "cross-env": "^7.0.3",
    "supertest": "^6.3.3",
    "vitest": "^1.6.0"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext js,json --exec node src/server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.js",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .js,.vue",
    "format": "prettier --write .",
    "migrate": "node ./scripts/run-migrations.js",
    "seed": "node ./scripts/seed.js"
  }
}